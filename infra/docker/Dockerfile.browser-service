FROM mcr.microsoft.com/playwright/python:v1.49.1-noble

ARG SERVICE_PATH
ARG SERVICE_MODULE
ENV SERVICE_MODULE=${SERVICE_MODULE}
WORKDIR /app

COPY packages/python-common /app/packages/python-common
COPY ${SERVICE_PATH} /app/service

RUN pip install --no-cache-dir -e /app/packages/python-common -e /app/service

EXPOSE 8080
CMD ["sh", "-c", "uvicorn ${SERVICE_MODULE} --host 0.0.0.0 --port ${PORT:-8080}"]
