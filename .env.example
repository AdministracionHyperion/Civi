# Shared
APP_ENV=development
LOG_LEVEL=INFO
INTERNAL_SERVICE_TOKEN=change-me-local-only

# Event bus
EVENT_PUBLISHER_MODE=disabled
EVENT_REDIS_URL=redis://localhost:6379/1
EVENT_CHANNEL_PREFIX=civi.events

# Channel gateway
CHANNEL_GATEWAY_PORT=8080
CHANNEL_GATEWAY_URL=http://localhost:8080
CONVERSATION_SERVICE_URL=http://localhost:8081
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
CHANNEL_PUBLIC_RATE_LIMIT_ENABLED=true
CHANNEL_PUBLIC_RATE_LIMIT_MAX=60
CHANNEL_PUBLIC_RATE_LIMIT_WINDOW_SECONDS=60
CHANNEL_CORS_ALLOWED_ORIGINS=

# Conversation service
CONVERSATION_SERVICE_PORT=8081
BOT_ORCHESTRATOR_URL=http://localhost:8082
CONVERSATION_REPOSITORY_MODE=memory
CONVERSATION_DATABASE_URL=postgresql+psycopg://civi:civi@localhost:5432/civi
CONVERSATION_AUTO_CREATE_SCHEMA=false
CONVERSATION_REDIS_URL=redis://localhost:6379/0

# Bot orchestrator
BOT_ORCHESTRATOR_PORT=8082
LLM_PROVIDER_MODE=disabled
LLM_PROVIDER=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_LLM_MODEL=
OPENAI_MODEL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=
DEEPSEEK_IMAGE_MODEL=
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=
GROQ_IMAGE_MODEL=
VEHICLE_SERVICE_URL=http://localhost:8083
PLACES_SERVICE_URL=http://localhost:8085
APPOINTMENT_SERVICE_URL=http://localhost:8086
MEDIA_SERVICE_URL=http://localhost:8088
KNOWLEDGE_SERVICE_URL=http://localhost:8094
QUOTE_SERVICE_URL=http://localhost:8091
BILLING_SERVICE_URL=http://localhost:8092
HANDOFF_SERVICE_URL=http://localhost:8093
NOTIFICATION_SERVICE_URL=http://localhost:8087
BOT_CONSULT_REPOSITORY_MODE=memory
BOT_CONSULT_DATABASE_URL=postgresql+psycopg://civi:civi@localhost:5432/civi
BOT_CONSULT_AUTO_CREATE_SCHEMA=false
BOT_CONSULT_WORKER_INTERVAL_SECONDS=5

# Vehicle service
VEHICLE_SERVICE_PORT=8083
RUNT_SERVICE_URL=http://localhost:8084
SIMIT_SERVICE_URL=http://localhost:8090
VEHICLE_CACHE_MODE=memory
VEHICLE_DATABASE_URL=postgresql+psycopg://civi:civi@localhost:5432/civi
VEHICLE_AUTO_CREATE_SCHEMA=false

# RUNT and SIMIT services
RUNT_SERVICE_PORT=8084
RUNT_PROVIDER_MODE=local
RUNT_PROVIDER_API_URL=
RUNT_PROVIDER_TIMEOUT_SECONDS=120
RUNT_PROVIDER_RETRIES=2
RUNT_PERSONA_PROVIDER_MODE=local
RUNT_PERSONA_PROVIDER_API_URL=
RUNT_PERSONA_PROVIDER_TIMEOUT_SECONDS=120
RUNT_PERSONA_PROVIDER_RETRIES=2
RUNT_BROWSER_URL=https://portalpublico.runt.gov.co/#/consulta-vehiculo/consulta/consulta-ciudadana
RUNT_BROWSER_TIMEOUT_SECONDS=75
RUNT_BROWSER_CAPTCHA_RETRIES=5
RUNT_BROWSER_HEADLESS=true
RUNT_BROWSER_EXECUTABLE_PATH=
CAPTCHA_API_KEY=
SIMIT_SERVICE_PORT=8090
SIMIT_PROVIDER_MODE=local
SIMIT_PROVIDER_API_URL=
SIMIT_PROVIDER_TIMEOUT_SECONDS=90
SIMIT_PROVIDER_RETRIES=2
SIMIT_BROWSER_URL=https://www.fcm.org.co/simit/#/estado-cuenta
SIMIT_BROWSER_TIMEOUT_SECONDS=75
SIMIT_BROWSER_HEADLESS=true
SIMIT_BROWSER_EXECUTABLE_PATH=
MANIZALES_PROVIDER_MODE=local
MANIZALES_BROWSER_URL=https://www.movilidadmanizales.com.co/portal-servicios/
MANIZALES_BROWSER_TIMEOUT_SECONDS=75
MANIZALES_BROWSER_HEADLESS=true
MANIZALES_BROWSER_EXECUTABLE_PATH=

# Places service
PLACES_SERVICE_PORT=8085
PLACES_REPOSITORY_MODE=memory
PLACES_DATABASE_URL=postgresql+psycopg://civi:civi@localhost:5432/civi
PLACES_AUTO_CREATE_SCHEMA=false
# none|sample|dataset — sample seeds 5 fixtures for local/dev only; never silent national import
PLACES_BOOTSTRAP_MODE=none
# Deprecated: prefer PLACES_BOOTSTRAP_MODE=sample
PLACES_AUTO_SEED_CATALOG=false
PLACES_SEARCH_RADIUS_KM=40
PLACES_GEOCODING_MODE=disabled
# Road-distance re-rank for GPS nearest (empty = Haversine only). Local demo:
OSRM_BASE_URL=https://router.project-osrm.org
OSRM_TIMEOUT_S=4
OSRM_MAX_DESTINATIONS=16
PLACES_CATALOG_PATH=services/places-service/data/raw/places_colombia_original.json
# Appointment → places eligibility
PLACES_SERVICE_URL=http://localhost:8085

# Appointment service
APPOINTMENT_SERVICE_PORT=8086
APPOINTMENT_REPOSITORY_MODE=memory
APPOINTMENT_DATABASE_URL=postgresql+psycopg://civi:civi@localhost:5432/civi
APPOINTMENT_AUTO_CREATE_SCHEMA=false
APPOINTMENT_REMINDER_LEAD_MINUTES=30
APPOINTMENT_PARTNER_REMINDER_LEAD_MINUTES=60
NOTIFICATION_SERVICE_URL=http://localhost:8087

# Notification service
NOTIFICATION_SERVICE_PORT=8087
NOTIFICATION_REPOSITORY_MODE=memory
NOTIFICATION_DATABASE_URL=postgresql+psycopg://civi:civi@localhost:5432/civi
NOTIFICATION_AUTO_CREATE_SCHEMA=false
WHATSAPP_PROVIDER_MODE=disabled
WHATSAPP_GRAPH_API_VERSION=v20.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
NOTIFICATION_WORKER_INTERVAL_SECONDS=30
NOTIFICATION_WORKER_LIMIT=50
NOTIFICATION_WORKER_DISPATCH_OUTBOX=false

# Media service
MEDIA_SERVICE_PORT=8088
MEDIA_REPOSITORY_MODE=memory
MEDIA_DATABASE_URL=postgresql+psycopg://civi:civi@localhost:5432/civi
MEDIA_AUTO_CREATE_SCHEMA=false
MEDIA_AUDIO_PROVIDER_MODE=disabled
MEDIA_IMAGE_PROVIDER_MODE=disabled
OPENAI_AUDIO_TRANSCRIPTION_MODEL=
OPENAI_IMAGE_VISION_MODEL=
OPENAI_IMAGE_EXTRACTION_PROMPT=Extrae el texto visible de esta imagen. Responde solo el texto encontrado.

# Knowledge, quote, billing and handoff services
KNOWLEDGE_SERVICE_PORT=8094
QUOTE_SERVICE_PORT=8091
BILLING_SERVICE_PORT=8092
HANDOFF_SERVICE_PORT=8093

# Admin service
ADMIN_SERVICE_PORT=8089
ADMIN_DATABASE_URL=postgresql+psycopg://civi:civi@localhost:5432/civi
ADMIN_AUDIT_REPOSITORY_MODE=memory
ADMIN_AUTO_CREATE_SCHEMA=false
ADMIN_USER=
ADMIN_PASSWORD=
