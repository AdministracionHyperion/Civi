# Copy this file to .env.deploy outside version control and fill real values.
# Do not commit .env.deploy.

# Runtime
APP_ENV=production
LOG_LEVEL=INFO
PUBLIC_BASE_URL=https://civi.example.com
INTERNAL_SERVICE_TOKEN=__replace_with_long_random_internal_token__

# Persistent stores
POSTGRES_USER=civi
POSTGRES_PASSWORD=__replace_with_postgres_password__
POSTGRES_DB=civi
DATABASE_URL=postgresql+psycopg://civi:__replace_with_postgres_password__@postgres:5432/civi
REDIS_PASSWORD=__replace_with_redis_password__
EVENT_PUBLISHER_MODE=redis
EVENT_REDIS_URL=redis://:__replace_with_redis_password__@redis:6379/1
EVENT_CHANNEL_PREFIX=civi.events

# Public ingress
# Generic default can be 8080. Change it only when the deployment host already uses that port.
CHANNEL_GATEWAY_PORT=8080
CHANNEL_BIND=0.0.0.0
CHANNEL_CORS_ALLOWED_ORIGINS=https://civi.example.com
CHANNEL_PUBLIC_RATE_LIMIT_ENABLED=true
CHANNEL_PUBLIC_RATE_LIMIT_MAX=60
CHANNEL_PUBLIC_RATE_LIMIT_WINDOW_SECONDS=60

# WhatsApp Cloud API
WHATSAPP_PROVIDER_MODE=meta
WHATSAPP_GRAPH_API_VERSION=v20.0
WHATSAPP_ACCESS_TOKEN=__replace_with_meta_whatsapp_access_token__
WHATSAPP_PHONE_NUMBER_ID=__replace_with_meta_phone_number_id__
WHATSAPP_BUSINESS_ACCOUNT_ID=__replace_with_meta_business_account_id__
WHATSAPP_VERIFY_TOKEN=__replace_with_meta_webhook_verify_token__
WHATSAPP_APP_SECRET=__replace_with_meta_app_secret__
WHATSAPP_SIGNATURE_REQUIRED=true

# LLM provider: deepseek | groq | openai
LLM_PROVIDER_MODE=deepseek
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=__replace_with_deepseek_api_key__
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_IMAGE_MODEL=deepseek-chat
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_IMAGE_MODEL=llama-3.2-90b-vision-preview
OPENAI_API_KEY=__replace_with_openai_api_key_for_audio_or_openai_mode__
OPENAI_BASE_URL=https://api.openai.com
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Media APIs
MEDIA_AUDIO_PROVIDER_MODE=openai
MEDIA_IMAGE_PROVIDER_MODE=deepseek
OPENAI_AUDIO_TRANSCRIPTION_MODEL=whisper-1
OPENAI_IMAGE_VISION_MODEL=gpt-4o-mini
OPENAI_IMAGE_EXTRACTION_PROMPT=Extrae el texto visible de esta imagen. Responde solo el texto encontrado.

# RUNT / SIMIT
RUNT_SERVICE_PORT=8084
RUNT_PROVIDER_MODE=browser
RUNT_PROVIDER_API_URL=
RUNT_PROVIDER_TIMEOUT_SECONDS=120
RUNT_PROVIDER_RETRIES=2
RUNT_PERSONA_PROVIDER_MODE=http
RUNT_PERSONA_PROVIDER_API_URL=__replace_with_runt_persona_provider_api_url__
RUNT_PERSONA_PROVIDER_TIMEOUT_SECONDS=120
RUNT_PERSONA_PROVIDER_RETRIES=2
RUNT_BROWSER_URL=https://portalpublico.runt.gov.co/#/consulta-vehiculo/consulta/consulta-ciudadana
RUNT_BROWSER_TIMEOUT_SECONDS=75
RUNT_BROWSER_CAPTCHA_RETRIES=5
RUNT_BROWSER_HEADLESS=true
RUNT_BROWSER_EXECUTABLE_PATH=
CAPTCHA_API_KEY=__replace_with_anti_captcha_api_key__
SIMIT_SERVICE_PORT=8090
SIMIT_PROVIDER_MODE=browser
SIMIT_PROVIDER_API_URL=
SIMIT_PROVIDER_TIMEOUT_SECONDS=90
SIMIT_PROVIDER_RETRIES=2
SIMIT_BROWSER_URL=https://www.fcm.org.co/simit/#/estado-cuenta
SIMIT_BROWSER_TIMEOUT_SECONDS=75
SIMIT_BROWSER_HEADLESS=true
SIMIT_BROWSER_EXECUTABLE_PATH=
MANIZALES_PROVIDER_MODE=browser
MANIZALES_BROWSER_URL=https://www.movilidadmanizales.com.co/portal-servicios/
MANIZALES_BROWSER_TIMEOUT_SECONDS=75
MANIZALES_BROWSER_HEADLESS=true
MANIZALES_BROWSER_EXECUTABLE_PATH=

# Bot orchestrator SQL & worker
BOT_CONSULT_REPOSITORY_MODE=sql
BOT_CONSULT_AUTO_CREATE_SCHEMA=true
BOT_CONSULT_WORKER_INTERVAL_SECONDS=5

# Service persistence
KNOWLEDGE_SERVICE_PORT=8094
CONVERSATION_REPOSITORY_MODE=sql
CONVERSATION_AUTO_CREATE_SCHEMA=true
VEHICLE_CACHE_MODE=sql
VEHICLE_AUTO_CREATE_SCHEMA=true
PLACES_REPOSITORY_MODE=sql
PLACES_AUTO_CREATE_SCHEMA=true
PLACES_AUTO_SEED_CATALOG=true
APPOINTMENT_REPOSITORY_MODE=sql
APPOINTMENT_AUTO_CREATE_SCHEMA=true
NOTIFICATION_REPOSITORY_MODE=sql
NOTIFICATION_AUTO_CREATE_SCHEMA=true
MEDIA_REPOSITORY_MODE=sql
MEDIA_AUTO_CREATE_SCHEMA=true
ADMIN_AUDIT_REPOSITORY_MODE=sql
ADMIN_AUTO_CREATE_SCHEMA=true

# Workers
NOTIFICATION_WORKER_INTERVAL_SECONDS=30
NOTIFICATION_WORKER_LIMIT=50
NOTIFICATION_WORKER_DISPATCH_OUTBOX=true

# Admin
ADMIN_BIND=127.0.0.1
ADMIN_SERVICE_PORT=8089
ADMIN_USER=__replace_with_admin_user__
ADMIN_PASSWORD=__replace_with_admin_password__
